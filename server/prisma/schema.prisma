generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums

enum UserRole {
  DOCTOR
  RADIOLOGIST
}

enum ScanStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum TumorType {
  GLIOMA
  MENINGIOMA
  PITUITARY
  NO_TUMOR
}

// Core Eentities / Models

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole

  patients Patient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("users")
}

model Patient {
  id             String  @id @default(uuid())
  fullName       String
  age            Int
  gender         String
  medicalHistory String? @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  scans Scan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@map("patients")
}

model Scan {
  id String @id @default(uuid())

  imageUrl     String
  cloudinaryId String @unique

  status ScanStatus @default(PENDING)

  tumorType    TumorType?
  confidence   Float?
  heatmapUrl   String?
  errorMessage String?    @db.Text

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  report Report?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([createdAt])
  @@map("scans")
}

model Report {
  id String @id @default(uuid())

  findings        String @db.Text
  impression      String @db.Text
  recommendations String @db.Text

  pdfUrl          String
  pdfCloudinaryId String? @unique

  scanId String @unique
  scan   Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scanId])
  @@index([createdAt])
  @@map("reports")
}
